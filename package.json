{
  "name": "zen-canvas",
  "version": "1.0.0",
  "description": "Lo-Fi music player with VHS Cyberpunk aesthetic — built with React, TypeScript & Framer Motion",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
